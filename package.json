    "better-sqlite3": "^11.0.0",
    "fast-glob": "^3.3.0",
    "openai": "^6.21.0",
    "picomatch": "^4.0.0",
    "sqlite-vec": "^0.1.7-alpha.2",
    "yaml": "^2.8.2"
  },
  "openclaw": {
